# ============================================================================
# Portfólio CAO — variáveis de ambiente (preencher em .env.local)
# Acesso sempre via src/lib/env.ts — NUNCA process.env direto (coding standard).
# ============================================================================

# Públicas (NEXT_PUBLIC_*) — expostas ao cliente
NEXT_PUBLIC_SITE_URL=https://carlosandre.ai
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/...
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=carlosandre.ai

# Privadas (server-side) — NUNCA expor / NUNCA em NEXT_PUBLIC_*
ANTHROPIC_API_KEY=
RESEND_API_KEY=
CONTACT_TO_EMAIL=contato@carlosandre.ai
NEWSLETTER_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
